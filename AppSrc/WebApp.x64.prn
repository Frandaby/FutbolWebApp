38733>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38736>>>        
38736>>>        Boolean bHasRecord
38736>>>        Handle hoDD
38736>>>        String sNombrePosicion
38736>>>        
38736>>>        Case Begin
38736>>>            Case (NavigateData.eNavigateType = nfFromMain)
38738>>>                // If from main, this is a propbably a main file Select to Zoom.
38738>>>                Case Break
38739>>>
38739>>>            Case (NavigateData.eNavigateType = nfFromParent)
38742>>>                // If from parent, this is a constrained drill down.
38742>>>                Case Break
38743>>>
38743>>>            Case (NavigateData.eNavigateType = nfFromChild)
38746>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38746>>>                Case Break
38747>>>
38747>>>            Case Else // must be nfUndefined
38747>>>
38747>>>        Case End
38747>>>
38747>>>        Send SetActionButtons
38748>>>        
38748>>>        Get Server to hoDD
38749>>>        Get HasRecord of hoDD to bHasRecord
38750>>>
38750>>>        //Para mostrar nombre de la posición y no ZoomPosicion
38750>>>        If (bHasRecord) Begin
38752>>>            // Para extraer el nombre de la posición directamente del Data Dictionary
38752>>>            Get Field_Current_Value of hoDD Field posicion.Nombre to sNombrePosicion
38753>>>            Move (Trim(sNombrePosicion)) to sNombrePosicion
38754>>>
38754>>>            Send SetHeaderCaption ("Posición: " + sNombrePosicion)
38755>>>            Send SetBreadcrumbCaption sNombrePosicion
38756>>>        End
38756>>>>
38756>>>        Else Begin 
38757>>>            Send SetHeaderCaption "Nueva posición"
38758>>>            Send SetBreadcrumbCaption "Nueva"
38759>>>        End
38759>>>>
38759>>>
38759>>>    End_Procedure
38760>>>
38760>>>End_Object 
