37825>>>>>        tWebNavigateData NavigateData
37825>>>>>        tWebNavigateData NavigateData
37825>>>>>        Boolean bHasRecord
37825>>>>>        Handle hoDD
37825>>>>>
37825>>>>>        Get Server to hoDD
37826>>>>>        Get GetNavigateData to NavigateData
37827>>>>>        Get HasRecord of hoDD to bHasRecord
37828>>>>>
37828>>>>>        // let's hide all buttons and then Show the ones we want
37828>>>>>        WebSet pbRender of oEditBtn to False
37829>>>>>        WebSet pbRender of oSaveBtn to False
37830>>>>>        WebSet pbRender of oCancelChangesBtn to False
37831>>>>>        WebSet pbRender of oDeleteBtn to False
37832>>>>>
37832>>>>>        If (NavigateData.bReadOnly) Begin
37834>>>>>            WebSet pbRender of oEditBtn to True
37835>>>>>        End
37835>>>>>>
37835>>>>>        Else Begin
37836>>>>>            WebSet pbRender of oSaveBtn to True
37837>>>>>            WebSet pbRender of oCancelChangesBtn to True
37838>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37839>>>>>        End
37839>>>>>>
37839>>>>>    End_Procedure
