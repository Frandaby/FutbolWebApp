38425>>>        WebSet pbRender of oSaveBtn to False
38426>>>        WebSet pbRender of oCancelChangesBtn to False
38427>>>        WebSet pbRender of oDeleteBtn to False
38428>>>
38428>>>        If (NavigateData.bReadOnly) Begin
