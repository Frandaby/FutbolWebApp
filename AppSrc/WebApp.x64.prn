38549>>>    Procedure SetActionButtons
38552>>>        tWebNavigateData NavigateData
38552>>>        tWebNavigateData NavigateData
38552>>>        Boolean bHasRecord
38552>>>        Handle hoDD
38552>>>
38552>>>        Get Server to hoDD
38553>>>        Get GetNavigateData to NavigateData
38554>>>        Get HasRecord of hoDD to bHasRecord
38555>>>
38555>>>        // let's hide all buttons and then Show the ones we want
38555>>>        WebSet pbRender of oEditBtn to False
38556>>>        WebSet pbRender of oSaveBtn to False
38557>>>        WebSet pbRender of oCancelChangesBtn to False
38558>>>        WebSet pbRender of oDeleteBtn to False
38559>>>
38559>>>        If (NavigateData.bReadOnly) Begin
38561>>>            WebSet pbRender of oEditBtn to True
38562>>>        End
38562>>>>
38562>>>        Else Begin
38563>>>            WebSet pbRender of oSaveBtn to True
38564>>>            WebSet pbRender of oCancelChangesBtn to True
38565>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38566>>>        End
38566>>>>
38566>>>    End_Procedure
38567>>>
38567>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38570>>>        // Close after save
38570>>>        Send NavigateClose Self
38571>>>    End_Procedure
38572>>>
38572>>>    // this will close the view after a delete
38572>>>    Procedure OnViewDeleted Handle hoDDO
38575>>>        Send NavigateClose Self
38576>>>    End_Procedure
38577>>>
38577>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38580>>>        Boolean bHasRecord
38580>>>        Handle hoDD
38580>>>        String sNombre sApellido
38580>>>        
38580>>>        Case Begin
38580>>>            Case (NavigateData.eNavigateType = nfFromMain)
38582>>>                // If from main, this is a propbably a main file Select to Zoom.
38582>>>                Case Break
38583>>>
38583>>>            Case (NavigateData.eNavigateType = nfFromParent)
38586>>>                // If from parent, this is a constrained drill down.
38586>>>                Case Break
38587>>>
38587>>>            Case (NavigateData.eNavigateType = nfFromChild)
38590>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38590>>>                Case Break
38591>>>
38591>>>            Case Else // must be nfUndefined
38591>>>
38591>>>        Case End
38591>>>
38591>>>        Send SetActionButtons
38592>>>        
38592>>>        Get Server to hoDD
38593>>>        Get HasRecord of hoDD to bHasRecord
38594>>>
38594>>>        If (bHasRecord) Begin
38596>>>            Get Field_Current_Value of hoDD Field jugador.Nombre to sNombre
38597>>>            Get Field_Current_Value of hoDD Field jugador.Apellido to sApellido
38598>>>            
38598>>>            Move (Trim(sNombre)) to sNombre
38599>>>            Move (Trim(sApellido)) to sApellido
38600>>>
38600>>>            Send SetHeaderCaption ("Jugador: " + sNombre + " " + sApellido)
38601>>>            Send SetBreadcrumbCaption (sNombre + " " + sApellido)
38602>>>        End
38602>>>>
38602>>>        Else Begin 
38603>>>            Send SetHeaderCaption "Nuevo Jugador"
38604>>>            Send SetBreadcrumbCaption "Nuevo"
38605>>>        End
38605>>>>
38605>>>
38605>>>    End_Procedure
38606>>>    
38606>>>   
38606>>>    Procedure OnGetHeaderCaption String ByRef sCaption String ByRef sSubCaption
38609>>>        String sNombre sApellido
38609>>>        Boolean bHasRecord
38609>>>        Handle hoDD
38609>>>        
38609>>>        Get Server to hoDD
38610>>>        Get HasRecord of hoDD to bHasRecord
38611>>>        
38611>>>        //Para que se muestre nombres y apellidos en vez de ZoomJugador tal cual
38611>>>        If (bHasRecord) Begin
38613>>>            Get Field_Current_Value of hoDD Field jugador.Nombre to sNombre
38614>>>            Get Field_Current_Value of hoDD Field jugador.Apellido to sApellido
38615>>>            
38615>>>            Move (Trim(sNombre) + " " + Trim(sApellido)) to sCaption
38616>>>            Move "Ficha de Jugador" to sSubCaption
38617>>>        End
38617>>>>
38617>>>        Else Begin
38618>>>            Move "Nuevo Jugador" to sCaption
38619>>>            Move "" to sSubCaption
38620>>>        End
38620>>>>
38620>>>    End_Procedure
38621>>>
38621>>>End_Object 
