39296>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
39299>>>        Boolean bHasRecord
39299>>>        Handle hoDD
39299>>>        String sNombreliga
39299>>>        
39299>>>        Case Begin
39299>>>            Case (NavigateData.eNavigateType = nfFromMain)
39301>>>                // If from main, this is a propbably a main file Select to Zoom.
39301>>>                Case Break
39302>>>
39302>>>            Case (NavigateData.eNavigateType = nfFromParent)
39305>>>                // If from parent, this is a constrained drill down.
39305>>>                Send Rebuild_Constraints of oequipo_DD
39306>>>                Case Break
39307>>>
39307>>>            Case (NavigateData.eNavigateType = nfFromChild)
39310>>>                // If from child, this is a probably a parent Zoom from a Zoom.
39310>>>                Case Break
39311>>>
39311>>>            Case Else // must be nfUndefined
39311>>>
39311>>>        Case End
39311>>>
39311>>>        Send SetActionButtons
39312>>>        Send Rebuild_Constraints of oliga_DD // 
39313>>>        Send SetActionButtons
39314>>>        WebSet pbRender of oEquiposBtn to True
39315>>>
39315>>>        Get Server to hoDD
39316>>>        Get HasRecord of hoDD to bHasRecord
39317>>>
39317>>>        //Para mostrar el nombre de la liga y no ZoomLiga
39317>>>        If (bHasRecord) Begin
39319>>>            // Extraemos el nombre de la liga directamente del Data Dictionary
39319>>>            Get Field_Current_Value of hoDD Field liga.Nombre to sNombreLiga
39320>>>            Move (Trim(sNombreLiga)) to sNombreLiga
39321>>>
39321>>>            Send SetHeaderCaption ("Liga: " + sNombreLiga)
39322>>>            Send SetBreadcrumbCaption sNombreLiga
39323>>>        End
39323>>>>
39323>>>        Else Begin 
39324>>>            Send SetHeaderCaption "Nueva liga"
39325>>>            Send SetBreadcrumbCaption "Nueva"
39326>>>        End
39326>>>>
39326>>>        
39326>>>    End_Procedure
