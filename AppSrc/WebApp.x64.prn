37857>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37857>>>>>                Case Break
37858>>>>>
37858>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37861>>>>>                // If from parent, this is a constrained drill down.
37861>>>>>                Case Break
37862>>>>>
37862>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37865>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37865>>>>>                Case Break
37866>>>>>
37866>>>>>            Case Else // must be nfUndefined
37866>>>>>
37866>>>>>        Case End
