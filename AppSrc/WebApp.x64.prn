39268>>>    Procedure SetActionButtons
39271>>>        tWebNavigateData NavigateData
39271>>>        tWebNavigateData NavigateData
39271>>>        Boolean bHasRecord
39271>>>        Handle hoDD
39271>>>
39271>>>        Get Server to hoDD
39272>>>        Get GetNavigateData to NavigateData
39273>>>        Get HasRecord of hoDD to bHasRecord
39274>>>
39274>>>        // let's hide all buttons and then Show the ones we want
39274>>>        WebSet pbRender of oEditBtn to False
39275>>>        WebSet pbRender of oSaveBtn to False
39276>>>        WebSet pbRender of oCancelChangesBtn to False
39277>>>        WebSet pbRender of oDeleteBtn to False
39278>>>
39278>>>        If (NavigateData.bReadOnly) Begin
39280>>>            WebSet pbRender of oEditBtn to True
39281>>>        End
39281>>>>
39281>>>        Else Begin
39282>>>            WebSet pbRender of oSaveBtn to True
39283>>>            WebSet pbRender of oCancelChangesBtn to True
39284>>>            WebSet pbRender of oDeleteBtn to bHasRecord
39285>>>        End
39285>>>>
39285>>>    End_Procedure
